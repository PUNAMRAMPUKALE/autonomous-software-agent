import os
import subprocess
from typing import Optional, Tuple


class GitError(Exception):
    pass


class GitTool:
    def __init__(self, workdir: str = "repos"):
        self.workdir = workdir
        os.makedirs(self.workdir, exist_ok=True)

    def _run(self, args, cwd: Optional[str] = None) -> Tuple[int, str, str]:
        proc = subprocess.Popen(
            args,
            cwd=cwd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
        out, err = proc.communicate()
        return proc.returncode, out.strip(), err.strip()

    def _build_auth_url(self, repo_url: str) -> str:
        token = os.environ.get("GITHUB_TOKEN")
        if not token:
            return repo_url
        # insert token into https URL: https://<token>@github.com/owner/repo.git
        if repo_url.startswith("https://") and "@" not in repo_url:
            return repo_url.replace("https://", f"https://{token}@", 1)
        return repo_url

    def clone(self, repo_url: str, dest_name: Optional[str] = None) -> str:
        if not repo_url:
            raise GitError("Repository URL is required.")
        url = self._build_auth_url(repo_url)
        target = dest_name or self._infer_name(repo_url)
        dest_path = os.path.join(self.workdir, target)

        if os.path.isdir(os.path.join(dest_path, ".git")):
            # Already cloned; convert to authenticated remote if token available
            self.set_remote_url(dest_path, url)
            return dest_path

        code, out, err = self._run(["git", "clone", url, target], cwd=self.workdir)
        if code != 0:
            raise GitError(f"git clone failed: {err or out}")
        return dest_path

    def set_remote_url(self, repo_path: str, url: str) -> None:
        code, out, err = self._run(["git", "remote", "set-url", "origin", url], cwd=repo_path)
        if code != 0:
            raise GitError(f"git remote set-url failed: {err or out}")

    def default_branch(self, repo_path: str) -> str:
        # Try symbolic-ref first
        code, out, err = self._run(["git", "symbolic-ref", "refs/remotes/origin/HEAD"], cwd=repo_path)
        if code == 0 and out:
            # refs/remotes/origin/HEAD -> refs/remotes/origin/main
            branch = out.split("/")[-1]
            return branch

        # Fallback to ls-remote
        code, out, err = self._run(["git", "ls-remote", "--symref", "origin", "HEAD"], cwd=repo_path)
        if code == 0:
            for line in out.splitlines():
                if line.startswith("ref:") and "HEAD" in line:
                    # ref: refs/heads/main	HEAD
                    parts = line.split()
                    if len(parts) >= 3:
                        ref = parts[1]
                        return ref.split("/")[-1]

        # Common defaults
        for candidate in ("main", "master"):
            code, _, _ = self._run(["git", "rev-parse", f"origin/{candidate}"], cwd=repo_path)
            if code == 0:
                return candidate

        raise GitError("Unable to determine default branch.")

    def checkout(self, repo_path: str, branch: str) -> None:
        code, out, err = self._run(["git", "checkout", branch], cwd=repo_path)
        if code != 0:
            # create local branch tracking origin/branch
            code2, out2, err2 = self._run(["git", "checkout", "-b", branch, f"origin/{branch}"], cwd=repo_path)
            if code2 != 0:
                raise GitError(f"git checkout failed: {err or out}; {err2 or out2}")

    def pull(self, repo_path: str) -> None:
        code, out, err = self._run(["git", "pull", "--ff-only"], cwd=repo_path)
        if code != 0:
            raise GitError(f"git pull failed: {err or out}")

    def build(self, repo_path: str) -> bool:
        # Try common build systems in order
        # 1) make
        if os.path.isfile(os.path.join(repo_path, "Makefile")):
            code, out, err = self._run(["make"], cwd=repo_path)
            return code == 0
        # 2) npm/yarn/pnpm
        if os.path.isfile(os.path.join(repo_path, "package.json")):
            # prefer npm ci if lockfile present
            if os.path.isfile(os.path.join(repo_path, "package-lock.json")):
                code, out, err = self._run(["npm", "ci"], cwd=repo_path)
                if code != 0:
                    return False
            else:
                code, out, err = self._run(["npm", "install"], cwd=repo_path)
                if code != 0:
                    return False
            # run build if available
            code, out, err = self._run(["npm", "run", "build", "--if-present"], cwd=repo_path)
            return code == 0
        # 3) Python: requirements.txt and optional build/test
        req = os.path.join(repo_path, "requirements.txt")
        if os.path.isfile(req):
            code, out, err = self._run(["python", "-m", "pip", "install", "-r", "requirements.txt"], cwd=repo_path)
            if code != 0:
                return False
            setup_py = os.path.join(repo_path, "setup.py")
            pyproject = os.path.join(repo_path, "pyproject.toml")
            if os.path.isfile(setup_py):
                code, out, err = self._run(["python", "setup.py", "build"], cwd=repo_path)
                return code == 0
            if os.path.isfile(pyproject):
                code, out, err = self._run(["python", "-m", "build"], cwd=repo_path)
                return code == 0
            return True
        # 4) Gradle
        if os.path.isfile(os.path.join(repo_path, "build.gradle")) or os.path.isfile(os.path.join(repo_path, "build.gradle.kts")):
            wrapper = "./gradlew" if os.path.isfile(os.path.join(repo_path, "gradlew")) else "gradle"
            code, out, err = self._run([wrapper, "build", "-x", "test"], cwd=repo_path)
            return code == 0
        # 5) Maven
        if os.path.isfile(os.path.join(repo_path, "pom.xml")):
            mvn = "mvnw" if os.path.isfile(os.path.join(repo_path, "mvnw")) else "mvn"
            cmd = [f"./{mvn}" if mvn.endswith("w") else mvn, "-q", "-DskipTests", "package"]
            code, out, err = self._run(cmd, cwd=repo_path)
            return code == 0

        # If no known build system, consider build "verified" as True
        return True

    def _infer_name(self, repo_url: str) -> str:
        name = repo_url.rstrip("/").split("/")[-1]
        if name.endswith(".git"):
            name = name[:-4]
        return name